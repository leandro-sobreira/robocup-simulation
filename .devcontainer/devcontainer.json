{
    "name": "RoboCup Simulation",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
    "features": {
        "ghcr.io/bascodes/devcontainer-features/desktop:0": {}
    },
    "remoteEnv": {
        "INSTALL_DIR": "${containerWorkspaceFolder}/installs",
        "PATH": "${containerWorkspaceFolder}/installs/bin:${containerEnv:PATH}",
        "LD_LIBRARY_PATH": "${containerWorkspaceFolder}/installs/lib:${containerEnv:LD_LIBRARY_PATH}",
        "CPATH": "${containerWorkspaceFolder}/installs/include:${containerEnv:CPATH}",
        "LIBRARY_PATH": "${containerWorkspaceFolder}/installs/lib:${containerEnv:LIBRARY_PATH}"
    },
    "updateContentCommand": "sudo apt-get update && sudo apt-get install -y x11vnc xvfb fluxbox novnc wmctrl build-essential libboost-all-dev flex bison libaudio-dev libxt-dev libglib2.0-dev libqt5gui5 qtbase5-dev qt5-qmake",
    
    // ESTA LINHA EXECUTA TODA VEZ QUE A MÁQUINA LIGA
    "postStartCommand": "sudo /usr/local/share/desktop-init.sh",
    
    // Configurações para garantir que as portas fiquem visíveis
    "forwardPorts": [6080],
    "portsAttributes": {
        "6080": {
            "label": "Desktop Virtual",
            "onAutoForward": "notify"
        }
    }
}